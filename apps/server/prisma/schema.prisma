generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  LOCKED
  SUSPENDED
}
enum MatchMode {
  TRAINING
  RANKED
}
enum MatchStatus {
  WAITING
  LOADING
  ACTIVE
  FINISHED
  CANCELLED
}
enum MatchResult {
  WIN
  LOSS
  DRAW
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique @db.VarChar(24)
  email              String   @unique @db.VarChar(254)
  passwordHash       String
  emailVerifiedAt    DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  lastLoginAt        DateTime?
  status             UserStatus @default(ACTIVE)
  failedLoginAttempts Int @default(0)
  lockedUntil        DateTime?
  profile            PlayerProfile?
  verificationTokens VerificationToken[]
  recoveryTokens     RecoveryToken[]
  sessions           Session[]
  matchParticipants  MatchParticipant[]
  wonMatches         Match[] @relation("Winner")
}

model VerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
}

model RecoveryToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String   @unique
  userAgent        String?  @db.VarChar(300)
  ipHash           String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, expiresAt])
}

model PlayerProfile {
  userId             String @id
  level              Int    @default(1)
  experience         Int    @default(0)
  totalAura          Int    @default(0)
  currentRank        String @default("SEM_PRESENCA")
  mmr                 Int    @default(1000)
  wins                Int    @default(0)
  losses              Int    @default(0)
  winStreak           Int    @default(0)
  tutorialCompleted   Boolean @default(false)
  selectedCosmetics   Json @default("{}")
  audioSettings       Json @default("{\"master\":0.8,\"music\":0.6,\"effects\":0.8,\"muted\":false}")
  graphicsSettings    Json @default("{\"quality\":\"AUTO\",\"reducedMotion\":false,\"cameraShake\":true}")
  user                User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([mmr(sort: Desc)])
}

model Match {
  id            String @id @default(cuid())
  mode          MatchMode
  status        MatchStatus
  seed          Int
  startedAt     DateTime?
  endedAt       DateTime?
  winnerId      String?
  finishReason  String?
  serverVersion String @default("1.0.0")
  winner        User? @relation("Winner", fields: [winnerId], references: [id])
  participants  MatchParticipant[]
  eventAudit    MatchEvent[]
  @@index([status, startedAt])
}

model MatchParticipant {
  matchId        String
  userId         String
  score          Int @default(0)
  aura           Int @default(0)
  remainingEgo   Int @default(100)
  highestCombo   Int @default(0)
  accuracy       Float @default(0)
  perfectActions Int @default(0)
  mistakes       Int @default(0)
  spamViolations Int @default(0)
  mmrBefore      Int
  mmrAfter       Int?
  disconnectedAt DateTime?
  result          MatchResult?
  match           Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user            User @relation(fields: [userId], references: [id])
  @@id([matchId, userId])
  @@index([userId, matchId])
}

model MatchEvent {
  id        BigInt @id @default(autoincrement())
  matchId   String
  type      String
  sequence  Int
  payload   Json
  createdAt DateTime @default(now())
  match     Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  @@index([matchId, sequence])
}

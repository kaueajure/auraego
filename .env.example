# Runtime
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/aura_ego

# Auth (use two different random values with 32+ characters)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_VERIFICATION_SECRET=
EMAIL_VERIFICATION_EXPIRES_IN=24h

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Aura & Ego
SMTP_FROM_EMAIL=

# Realtime and game
SOCKET_CORS_ORIGIN=http://localhost:5173
MAX_LATENCY_COMPENSATION_MS=150
RECONNECT_WINDOW_MS=15000

# Frontend (copy these to apps/web/.env when origins differ)
VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000

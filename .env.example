# Runtime
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://auraego.com.br/
BACKEND_URL=http://auraego.com.br/

# MySQL 8 (Hostinger: Bancos de dados → Gerenciamento)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=aura_ego
DATABASE_USERNAME=usuario
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_POOL_SIZE=25

# Auth (use two different random values with 32+ characters)
JWT_ACCESS_SECRET=nynJZiIYuwmcfF1mlmI2eHCiBeDRvA6x
JWT_REFRESH_SECRET=sZV039getZyRCvgwDbPvZkk7Aflk5rEG
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_VERIFICATION_SECRET=
EMAIL_VERIFICATION_EXPIRES_IN=24h

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Aura & Ego
SMTP_FROM_EMAIL=

# Realtime and game
SOCKET_CORS_ORIGIN=http://localhost:5173
MAX_LATENCY_COMPENSATION_MS=150
RECONNECT_WINDOW_MS=15000
MAX_CONCURRENT_ROOMS=200
MAX_QUEUE_SIZE=500

# Frontend development only (apps/web/.env.development).
# Em produção NÃO defina VITE_API_URL / VITE_SOCKET_URL — o browser
# usa o mesmo domínio HTTPS do Express (auraego.com.br).
# VITE_API_URL=
# VITE_SOCKET_URL=

{
  "name": "aura-ego",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "app.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run build -w @aura-ego/shared && concurrently -n server,web -c yellow,cyan \"npm run dev -w @aura-ego/server\" \"npm run dev -w @aura-ego/web\"",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build -w @aura-ego/shared && npm run build -w @aura-ego/server && npm run build -w @aura-ego/web && npm run build:bundle",
    "build:bundle": "node scripts/build-hostinger.mjs",
    "start": "npm start -w @aura-ego/server",
    "db:migrate": "npm run db:migrate -w @aura-ego/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "concurrently": "^9.2.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.32.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.38.0"
  },
  "engines": {
    "node": ">=22"
  }
}
